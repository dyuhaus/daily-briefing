# --- Credentials — NEVER commit ---
.env
.env.*
!.env.example
credentials.env
*credentials.env
*.key
*.pem
*.p12
*.pfx
*secret*
*token*
# YouTube cookies (used by yt-dlp to authenticate for age-restricted content)
config/youtube_cookies.txt
config/www.youtube.com_cookies.txt

