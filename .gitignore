dist/
build/
venv/
.venv/
.coverage
htmlcov/

# --- Node.js ---
node_modules/
package-lock.json
yarn.lock
.npm/

# --- Pipeline outputs — audio + logs are regenerable + noisy ---
output/audio/
output/*.log
output/**/*.log
output/usage_log.jsonl

