# DailyBriefing — Environment Variables
# Copy to .env and fill in values, OR source these from an external credentials.env
# referenced by config/credentials.py. .env is gitignored; never commit.

# --- LLM ---
# Only required if switching config/settings.json `llm.backend` to "api".
# Default backend is Claude Code CLI (subscription, no API key needed).
# ANTHROPIC_API_KEY=

# --- Gemini grounded search (used by ai_industry, company_news, market_news scanners) ---
GEMINI_API_KEY=your-gemini-api-key
# GOOGLE_API_KEY= (alternative name for the same key, depending on SDK)

# --- YouTube scanner ---
# yt-dlp uses cookies from browser by default; no key required.

# --- Email delivery (SMTP) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
EMAIL_TO=your-email@gmail.com

# --- Telegram (audio briefing delivery) ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- NotebookLM (audio pipeline) ---
# Authentication is handled by `nlm login` CLI via the NotebookLM MCP server.
# No static key is set here; tokens live in the MCP auth cache.
